<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= report.name %> - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .iscs0 { background: #FFFFFF; color: #000000; font: normal normal 12px/1.4 Arial, sans-serif; }
        .iscs1 { background: #C6D3EF; color: #000000; font: bold 12px/1.4 Arial, sans-serif; text-align: left; }
        .iscs2 { background: #FFFFFF; color: #000000; text-align: left; }
        .iscs3 { background: #FFFFFF; color: #000000; text-align: right; }
        .iscs4 { background: #F0F0F0; color: #000000; font: bold 12px/1.4 Arial, sans-serif; text-align: right; }
        .iscs6 { background: #FFFFFF; color: #000000; font: bold 12px/1.4 Arial, sans-serif; text-align: left; }
        .iscs7 { background: #FFFFFF; color: #000000; text-align: left; }
        .iscs9 { background: #D9E2F3; color: #000; font: bold 13px/1.4 Arial, sans-serif; text-align: right; }

        .report-table { border-collapse: collapse; border: 1px solid #000; }
        .report-table td { border: 1px solid #888; padding: 3px 6px; white-space: nowrap; font-size: 12px; }

        .btn-export { background: #28a745; color: white; border: none; padding: 6px 16px; border-radius: 4px; cursor: pointer; font-size: 13px; }
        .btn-export:hover { background: #218838; color: white; }

        .filter-bar { background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; }
        .filter-bar input[type="date"] { border: 1px solid #ccc; border-radius: 4px; padding: 4px 8px; font-size: 13px; }
        .filter-bar label { font-size: 13px; font-weight: 600; margin-right: 4px; }

        .filter-row select { width: 100%; border: 1px solid #aaa; border-radius: 3px; padding: 2px 4px; font-size: 11px; box-sizing: border-box; max-height: 26px; cursor: pointer; background: #fff; }
        .filter-row { background: #eef3ff; }

        @media print { .no-print { display: none !important; } .filter-row { display: none !important; } }
        @media (max-width: 768px) { .report-table td { padding: 2px 4px; font-size: 11px; } }
    </style>
</head>
<body class="iscs0">
    <nav class="navbar navbar-dark bg-dark no-print">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-bar-chart-line"></i> <%= title %></a>
            <div class="d-flex gap-2">
                <button class="btn-export" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
                <button class="btn-export" onclick="exportCSV()"><i class="bi bi-filetype-csv"></i> CSV</button>
                <a href="/" class="btn-export" style="background:#6c757d;text-decoration:none;"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-3 px-3">
        <div class="d-flex justify-content-between align-items-center mb-2 no-print">
            <div>
                <h5 class="mb-0"><i class="<%= report.icon || 'bi bi-file-earmark-text' %>"></i> <%= report.name %></h5>
                <small class="text-muted"><%= report.description %></small>
            </div>
        </div>

        <div class="filter-bar no-print">
            <form method="POST" action="/report/<%= report.id %>" id="filterForm" class="d-flex align-items-center gap-3 flex-wrap">
                <div><label>From:</label><input type="date" name="DateFrom" id="DateFrom" value="<%= params && params.DateFrom ? params.DateFrom : '' %>"></div>
                <div><label>To:</label><input type="date" name="DateTo" id="DateTo" value="<%= params && params.DateTo ? params.DateTo : '' %>"></div>
                <button type="submit" class="btn-export" style="background:#007bff;"><i class="bi bi-search"></i> Run</button>
                <button type="button" class="btn-export" style="background:#6c757d;" onclick="clearFilters()"><i class="bi bi-x-circle"></i> Clear Filters</button>
            </form>
        </div>

        <% if (error) { %>
        <div class="alert alert-danger no-print"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>
        <% } %>

        <% if (data && data.length > 0) { %>
        <div style="overflow-x: auto;">
            <table class="report-table" id="reportTable">
                <thead>
                    <tr>
                        <td class="iscs7" colspan="<%= columns.length %>" style="font-size:14px;font-weight:bold;">&nbsp; <%= report.name %></td>
                    </tr>
                    <tr>
                        <% columns.forEach(function(col) { %>
                        <td class="<%= col.style || 'iscs1' %>">&nbsp;<%= col.label %>&nbsp;</td>
                        <% }); %>
                    </tr>
                    <% if (filters && filters.length > 0) { %>
                    <tr class="filter-row no-print">
                        <% filters.forEach(function(f) { %>
                        <td>
                            <% if (f.type === 'select') { %>
                            <select id="f_<%= f.id %>" onchange="filterTable()"><option value="">All</option>
                                <% if (f.options && f.options.forEach) { f.options.forEach(function(v) { %><option value="<%= v %>"><%= v %></option><% }); } %>
                                <% if (f.presets && f.presets.forEach) { f.presets.forEach(function(p) { %><option value="<%= p.value %>"><%= p.label %></option><% }); } %>
                            </select>
                            <% } %>
                        </td>
                        <% }); %>
                    </tr>
                    <% } %>
                </thead>
                <tbody>
                <%
                    function formatVal(key, val, col) {
                        if (val === null || val === undefined) return '0.00';
                        if (col.type === 'money') return parseFloat(val).toFixed(2);
                        if (col.type === 'decimal3') return parseFloat(val).toFixed(3);
                        if (col.type === 'pct') return parseFloat(val).toFixed(2);
                        if (col.type === 'int') return parseInt(val).toString();
                        if (col.type === 'date') {
                            var d = new Date(val);
                            return (d.getMonth()+1).toString().padStart(2,'0') + '/' + d.getDate().toString().padStart(2,'0') + '/' + d.getFullYear();
                        }
                        if (col.type === 'hour') return parseInt(val).toString().padStart(2,'0') + ':00';
                        if (val instanceof Date) {
                            return val.toLocaleDateString('en-US', {month:'2-digit',day:'2-digit',year:'numeric'});
                        }
                        return String(val);
                    }

                    var grouped = {};
                    var groupKey = report.groupBy || null;
                    var grandTotals = {};
                    columns.forEach(function(c) { if (c.type === 'money' || c.type === 'decimal3' || c.type === 'int') grandTotals[c.key] = 0; });

                    if (groupKey) {
                        data.forEach(function(row) {
                            var gk = row[groupKey] || 'Unknown';
                            if (!grouped[gk]) grouped[gk] = [];
                            grouped[gk].push(row);
                            columns.forEach(function(c) {
                                if (c.type === 'money' || c.type === 'decimal3' || c.type === 'int') {
                                    grandTotals[c.key] = (grandTotals[c.key] || 0) + (parseFloat(row[c.key]) || 0);
                                }
                            });
                        });
                    } else {
                        grouped['_all'] = data;
                        data.forEach(function(row) {
                            columns.forEach(function(c) {
                                if (c.type === 'money' || c.type === 'decimal3' || c.type === 'int') {
                                    grandTotals[c.key] = (grandTotals[c.key] || 0) + (parseFloat(row[c.key]) || 0);
                                }
                            });
                        });
                    }

                    var groupKeys = Object.keys(grouped).sort();
                    for (var gi = 0; gi < groupKeys.length; gi++) {
                        var gk = groupKeys[gi];
                        var items = grouped[gk];
                        var totalRows = groupKey ? items.length + 1 : items.length;
                        var groupSums = {};
                        columns.forEach(function(c) { if (c.type === 'money' || c.type === 'decimal3' || c.type === 'int') groupSums[c.key] = 0; });

                        for (var ii = 0; ii < items.length; ii++) {
                            var row = items[ii];
                            columns.forEach(function(c) {
                                if (c.type === 'money' || c.type === 'decimal3' || c.type === 'int') {
                                    groupSums[c.key] = (groupSums[c.key] || 0) + (parseFloat(row[c.key]) || 0);
                                }
                            });
                %>
                    <tr data-gk="<%= groupKey ? gk : '' %>" data-idx="<%= ii %>"<% columns.forEach(function(c) { %> data-<%= c.key.replace(/([a-z0-9])([A-Z])/g,'$1-$2').toLowerCase() %>="<%= row[c.key] !== null && row[c.key] !== undefined ? row[c.key] : '' %>"<% }); %>>
                        <% columns.forEach(function(col, ci) { %>
                            <% if (groupKey && ci < 1 && ii === 0) { %>
                            <td class="iscs2" rowspan="<%= totalRows %>">&nbsp;<%= gk %>&nbsp;</td>
                            <% } else if (!groupKey || ci > 0) { %>
                            <td class="<%= col.dataStyle || 'iscs3' %>">&nbsp;<%= formatVal(col.key, row[col.key], col) %>&nbsp;</td>
                            <% } %>
                        <% }); %>
                    </tr>
                <%
                        }
                        if (groupKey) {
                %>
                    <tr class="subtotal-row" style="background:#F0F0F0;">
                        <td class="iscs4">&nbsp;<%= gk %> total&nbsp;</td>
                        <% columns.slice(1).forEach(function(col) { %>
                            <% if (col.grandTotal) { %>
                            <td class="iscs4">&nbsp;<%= col.grandTotal %>&nbsp;</td>
                            <% } else if (col.formula) { var nv = parseFloat(groupSums[col.formula.num])||0; var dv = parseFloat(groupSums[col.formula.den])||0; %>
                            <td class="iscs4">&nbsp;<%= dv > 0 ? (nv/dv).toFixed(2) : '0.00' %>&nbsp;</td>
                            <% } else { %>
                            <td class="iscs4">&nbsp;<%= formatVal(col.key, groupSums[col.key], col) %>&nbsp;</td>
                            <% } %>
                        <% }); %>
                    </tr>
                <%
                        }
                    }
                %>
                    <tr id="grandTotalRow">
                        <td class="iscs9" colspan="<%= groupKey ? 1 : 1 %>">&nbsp;Grand Total&nbsp;</td>
                        <% columns.slice(1).forEach(function(col) { %>
                            <% if (col.grandTotal) { %>
                            <td class="iscs9">&nbsp;<%= col.grandTotal %>&nbsp;</td>
                            <% } else if (col.formula) { var nv = parseFloat(grandTotals[col.formula.num])||0; var dv = parseFloat(grandTotals[col.formula.den])||0; %>
                            <td class="iscs9">&nbsp;<%= dv > 0 ? (nv/dv).toFixed(2) : '0.00' %>&nbsp;</td>
                            <% } else { %>
                            <td class="iscs9">&nbsp;<%= formatVal(col.key, grandTotals[col.key], col) %>&nbsp;</td>
                            <% } %>
                        <% }); %>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="mt-2 mb-4 no-print">
            <small class="text-muted">
                <i class="bi bi-info-circle"></i>
                Showing <span id="visibleCount"><%= data.length %></span> rows | Generated: <%= new Date().toLocaleString() %>
            </small>
        </div>
        <% } else if (!error) { %>
        <div class="text-center text-muted py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <p class="mt-2">No data found. Select a date range and click Run.</p>
        </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        var colDefs = <%= JSON.stringify(columns || []) %>;
        var filterDefs = <%= JSON.stringify((filters || []).map(function(f) { return { id: f.id, key: f.key }; })) %>;

        function parseCompare(val, input) {
            input = input.trim();
            if (!input) return true;
            var num = parseFloat(val);
            if (input.indexOf('>=') === 0) return num >= parseFloat(input.slice(2));
            if (input.indexOf('<=') === 0) return num <= parseFloat(input.slice(2));
            if (input.indexOf('>') === 0) return num > parseFloat(input.slice(1));
            if (input.indexOf('<') === 0) return num < parseFloat(input.slice(1));
            if (input.indexOf('!=') === 0 || input.indexOf('<>') === 0) return num !== parseFloat(input.slice(2));
            if (input.indexOf('=') === 0) return num === parseFloat(input.slice(1));
            return String(val).toLowerCase().indexOf(input.toLowerCase()) !== -1;
        }

        function cellValue(row, key) {
            var attr = 'data-' + key.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
            return row.getAttribute(attr) || '';
        }

        function filterTable() {
            var vals = {};
            var hasFilter = false;
            filterDefs.forEach(function(f) {
                var el = document.getElementById('f_' + f.id);
                if (el && el.value) { vals[f.id] = el.value; hasFilter = true; }
            });

            var rows = document.querySelectorAll('#reportTable tbody tr[data-idx]');
            var visible = 0;
            rows.forEach(function(r) {
                var show = true;
                if (hasFilter) {
                    filterDefs.forEach(function(f) {
                        if (!show) return;
                        var v = vals[f.id];
                        if (!v) return;
                        if (f.key) {
                            var cval = cellValue(r, f.key);
                            if (!parseCompare(cval, v)) show = false;
                        } else {
                            if (r.innerText.toLowerCase().indexOf(v.toLowerCase()) === -1) show = false;
                        }
                    });
                }
                r.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            document.querySelectorAll('.subtotal-row').forEach(function(r) { r.style.display = ''; });
            document.getElementById('visibleCount').textContent = visible;

            // Recompute grand total
            var grandRow = document.getElementById('grandTotalRow');
            if (grandRow && visibleRows().length > 0) {
                var gTotals = {};
                colDefs.forEach(function(c) {
                    if (c.type === 'money' || c.type === 'decimal3' || c.type === 'int') gTotals[c.key] = 0;
                });
                visibleRows().forEach(function(r) {
                    colDefs.forEach(function(c) {
                        if (c.type === 'money' || c.type === 'decimal3' || c.type === 'int') {
                            gTotals[c.key] = (gTotals[c.key] || 0) + (parseFloat(cellValue(r, c.key)) || 0);
                        }
                    });
                });
                var cells = grandRow.querySelectorAll('td');
                var ci = 0;
                colDefs.slice(1).forEach(function(c) {
                    if (++ci >= cells.length) return;
                    var val;
                    if (c.formula) {
                        var nv = parseFloat(gTotals[c.formula.num]) || 0;
                        var dv = parseFloat(gTotals[c.formula.den]) || 0;
                        val = dv > 0 ? (nv/dv).toFixed(2) : '0.00';
                    } else if (c.grandTotal) {
                        val = c.grandTotal;
                    } else {
                        var raw = gTotals[c.key];
                        if (c.type === 'money' || c.type === 'avg') val = parseFloat(raw||0).toFixed(2);
                        else if (c.type === 'decimal3') val = parseFloat(raw||0).toFixed(3);
                        else if (c.type === 'int') val = parseInt(raw||0).toString();
                        else val = String(raw||'');
                    }
                    cells[ci].textContent = '\u00a0' + val + '\u00a0';
                });
            }
        }

        function visibleRows() {
            return document.querySelectorAll('#reportTable tbody tr[data-idx]:not([style*="display: none"])');
        }

        function exportCSV() {
            var table = document.getElementById('reportTable');
            if (!table) return;
            var csv = [];
            table.querySelectorAll('tr').forEach(function(row) {
                if (row.style.display === 'none' || row.classList.contains('filter-row')) return;
                var rowData = [];
                row.querySelectorAll('td, th').forEach(function(col) {
                    rowData.push('"' + col.innerText.trim().replace(/"/g, '""') + '"');
                });
                csv.push(rowData.join(','));
            });
            var blob = new Blob([csv.join('\n')], { type: 'text/csv;charset=utf-8;' });
            var link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = '<%= report.id %>-' + new Date().toISOString().slice(0,10) + '.csv';
            link.click();
        }

        function clearFilters() {
            filterDefs.forEach(function(f) {
                var el = document.getElementById('f_' + f.id);
                if (el) el.value = '';
            });
            filterTable();
        }

        document.getElementById('filterForm').addEventListener('submit', function(e) {
            if (!document.getElementById('DateFrom').value || !document.getElementById('DateTo').value) {
                e.preventDefault();
                alert('Please select both From and To dates.');
            }
        });
    </script>
</body>
</html>

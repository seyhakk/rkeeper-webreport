<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurants - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f0f2f5; }
        .hero { background: linear-gradient(135deg, #1a237e, #0d47a1, #01579b); color: white; padding: 28px 0 32px; }
        .restaurant-card { border: none; border-radius: 12px; transition: transform .15s, box-shadow .15s; cursor: pointer; }
        .restaurant-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,.12); border-color: #0d6efd; }
        .restaurant-link { text-decoration: none; color: inherit; }
        .key-badge { font-family: monospace; font-size: .8rem; background: #f0f0f0; padding: 4px 8px; border-radius: 4px; color: #666; }
        @media (max-width: 576px) { .hero h2 { font-size: 1.3rem; } }
    </style>
</head>
<body>
    <div class="hero">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-0"><i class="bi bi-bar-chart-line"></i> <%= title %></h2>
                <small class="opacity-75">R-Keeper 7 Central Report System</small>
            </div>
            <a href="/admin/restaurants" class="btn btn-outline-light btn-sm"><i class="bi bi-gear"></i> Admin</a>
        </div>
    </div>

    <div class="container" style="margin-top:-20px;">
        <h5 class="fw-semibold mb-3"><i class="bi bi-shop"></i> Select Restaurant</h5>
        <% if (restaurants && restaurants.length > 0) { %>
        <div class="row g-3">
            <% restaurants.forEach(function(r) { %>
            <div class="col-md-6 col-lg-4">
                <div class="card restaurant-card h-100" onclick="location.href='/r/<%= r.slug %>'">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div style="width:48px;height:48px;border-radius:12px;background:#e8f0fe;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">🏢</div>
                            <div>
                                <h5 class="mb-0"><%= r.name %></h5>
                                <small class="text-muted">/<%= r.slug %></small>
                            </div>
                        </div>
                        <div class="key-badge mb-3"><i class="bi bi-key"></i> <%= r.api_key.slice(0,12) %>*****</div>
                        <div class="mt-auto">
                            <span class="badge bg-primary"><i class="bi bi-bar-chart"></i> Open Reports</span>
                            <span class="badge bg-secondary bg-opacity-25 text-muted small"><%= r.created_at ? r.created_at.slice(0,10) : '' %></span>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
        <% } else { %>
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem;"></i>
            <p class="mt-2">No restaurants yet.</p>
            <a href="/admin/restaurants/new" class="btn btn-primary">Add Restaurant</a>
        </div>
        <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

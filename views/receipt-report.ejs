<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= report.name %> - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .iscs0 { background: #FFFFFF; color: #000000; font: normal normal 12px/1.4 Arial, sans-serif; }
        .iscs1 { background: #C6D3EF; color: #000000; font: bold 12px/1.4 Arial, sans-serif; text-align: left; }
        .iscs2 { background: #FFFFFF; color: #000000; text-align: left; }
        .iscs3 { background: #FFFFFF; color: #000000; text-align: right; }
        .iscs4 { background: #F0F0F0; color: #000000; font: bold 12px/1.4 Arial, sans-serif; text-align: right; }
        .iscs6 { background: #FFFFFF; color: #000000; font: bold 12px/1.4 Arial, sans-serif; text-align: left; }
        .iscs7 { background: #FFFFFF; color: #000000; text-align: left; }
        .iscs9 { background: #D9E2F3; color: #000; font: bold 13px/1.4 Arial, sans-serif; text-align: right; }

        .report-table { border-collapse: collapse; border: 1px solid #000; }
        .report-table td { border: 1px solid #888; padding: 3px 6px; white-space: nowrap; font-size: 12px; }

        .btn-export { background: #28a745; color: white; border: none; padding: 6px 16px; border-radius: 4px; cursor: pointer; font-size: 13px; }
        .btn-export:hover { background: #218838; color: white; }

        .filter-bar { background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; }
        .filter-bar input[type="date"] { border: 1px solid #ccc; border-radius: 4px; padding: 4px 8px; font-size: 13px; }
        .filter-bar label { font-size: 13px; font-weight: 600; margin-right: 4px; }

        .filter-row select { width: 100%; border: 1px solid #aaa; border-radius: 3px; padding: 2px 4px; font-size: 11px; box-sizing: border-box; max-height: 26px; cursor: pointer; background: #fff; }
        .filter-row { background: #eef3ff; }

        @media print { .no-print { display: none !important; } .filter-row { display: none !important; } }
        @media (max-width: 768px) { .report-table td { padding: 2px 4px; font-size: 11px; } }
    </style>
</head>
<body class="iscs0">
    <nav class="navbar navbar-dark bg-dark no-print">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-bar-chart-line"></i> <%= title %></a>
            <div class="d-flex gap-2">
                <button class="btn-export" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
                <button class="btn-export" onclick="exportCSV()"><i class="bi bi-filetype-csv"></i> CSV</button>
                <a href="/" class="btn-export" style="background:#6c757d;text-decoration:none;"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-3 px-3">
        <div class="d-flex justify-content-between align-items-center mb-2 no-print">
            <div>
                <h5 class="mb-0"><i class="bi bi-receipt text-danger"></i> <%= report.name %></h5>
                <small class="text-muted"><%= report.description %></small>
            </div>
        </div>

        <div class="filter-bar no-print">
            <form method="POST" action="/report/<%= report.id %>" id="filterForm" class="d-flex align-items-center gap-3 flex-wrap">
                <div><label>From:</label><input type="date" name="DateFrom" id="DateFrom" value="<%= params && params.DateFrom ? params.DateFrom : '' %>"></div>
                <div><label>To:</label><input type="date" name="DateTo" id="DateTo" value="<%= params && params.DateTo ? params.DateTo : '' %>"></div>
                <button type="submit" class="btn-export" style="background:#007bff;"><i class="bi bi-search"></i> Run</button>
                <button type="button" class="btn-export" style="background:#6c757d;" onclick="clearFilters()"><i class="bi bi-x-circle"></i> Clear Filters</button>
            </form>
        </div>

        <% if (error) { %>
        <div class="alert alert-danger no-print"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>
        <% } %>

        <% if (data && data.length > 0) { %>
        <div style="overflow-x: auto;">
            <%
                var grouped = {};
                var grandQty = 0, grandAmt = 0, grandPaid = 0, grandSurcharge = 0, grandDiscount = 0;
                data.forEach(function(row) {
                    var restaurant = row.Restaurant || 'Unknown';
                    if (!grouped[restaurant]) grouped[restaurant] = [];
                    grouped[restaurant].push(row);
                    grandQty += parseFloat(row.Quantity) || 0;
                    grandAmt += parseFloat(row.Amount) || 0;
                    grandPaid += parseFloat(row.PaidAmount) || 0;
                    grandSurcharge += parseFloat(row.Surcharge5Pct) || 0;
                    grandDiscount += parseFloat(row.DiscountSum) || 0;
                });
            %>
            <table class="report-table" id="reportTable">
                <thead>
                    <tr>
                        <td class="iscs7" colspan="8" style="font-size:14px;font-weight:bold;">&nbsp; <%= report.name %></td>
                    </tr>
                    <tr>
                        <td class="iscs1">&nbsp;Restaurant Name&nbsp;</td>
                        <td class="iscs1">&nbsp;Receipt Number&nbsp;</td>
                        <td class="iscs6">Quantity</td>
                        <td class="iscs6">Avg Price</td>
                        <td class="iscs6">Amount</td>
                        <td class="iscs6">Discount Sum</td>
                        <td class="iscs6">Paid Amount</td>
                        <td class="iscs6">SURCHARGE 5%'</td>
                    </tr>
                    <tr class="filter-row no-print">
                        <td><select id="f_rest" onchange="filterTable()"><option value="">All</option>
                            <% if (filterOpts && filterOpts.restaurants) { filterOpts.restaurants.forEach(function(v) { %><option value="<%= v %>"><%= v %></option><% }); } %>
                        </select></td>
                        <td><select id="f_rec" onchange="filterTable()"><option value="">All</option></select></td>
                        <td><select id="f_qty" onchange="filterTable()"><option value="">All</option><option value=">0">&gt; 0</option><option value=">=5">&ge; 5</option><option value=">=10">&ge; 10</option></select></td>
                        <td><select id="f_avg" onchange="filterTable()"><option value="">All</option><option value=">0">&gt; 0</option><option value=">5">&gt; 5</option><option value=">10">&gt; 10</option></select></td>
                        <td><select id="f_amt" onchange="filterTable()"><option value="">All</option><option value=">0">&gt; 0</option><option value=">10">&gt; 10</option><option value=">50">&gt; 50</option><option value=">100">&gt; 100</option></select></td>
                        <td><select id="f_disc" onchange="filterTable()"><option value="">All</option><option value="!=0">&ne; 0</option></select></td>
                        <td><select id="f_paid" onchange="filterTable()"><option value="">All</option><option value=">0">&gt; 0</option><option value=">10">&gt; 10</option><option value=">50">&gt; 50</option><option value=">100">&gt; 100</option></select></td>
                        <td><select id="f_sc" onchange="filterTable()"><option value="">All</option><option value=">0">&gt; 0</option><option value=">5">&gt; 5</option></select></td>
                    </tr>
                </thead>
                <tbody>
                <%
                    var restKeys = Object.keys(grouped).sort();
                    for (var ri = 0; ri < restKeys.length; ri++) {
                        var restaurant = restKeys[ri];
                        var receipts = grouped[restaurant];
                        var restTotalRows = receipts.length + 1;
                        var restRowNum = 0;
                        var restQty = 0, restAmt = 0, restPaid = 0, restSurcharge = 0, restDiscount = 0;
                        for (var ii = 0; ii < receipts.length; ii++) {
                            var row = receipts[ii];
                            restQty += parseFloat(row.Quantity) || 0;
                            restAmt += parseFloat(row.Amount) || 0;
                            restPaid += parseFloat(row.PaidAmount) || 0;
                            restSurcharge += parseFloat(row.Surcharge5Pct) || 0;
                            restDiscount += parseFloat(row.DiscountSum) || 0;
                %>
                    <tr data-rest="<%= restaurant %>" data-rec="<%= row.ReceiptNumber %>"
                        data-qty="<%= row.Quantity %>" data-avg="<%= row.AvgPrice %>" data-amt="<%= row.Amount %>"
                        data-disc="<%= row.DiscountSum %>" data-paid="<%= row.PaidAmount %>" data-sc="<%= row.Surcharge5Pct %>">
                        <% if (restRowNum === 0) { %><td class="iscs2" rowspan="<%= restTotalRows %>">&nbsp;<%= restaurant %>&nbsp;</td><% } %>
                        <td class="iscs2">&nbsp;<%= row.ReceiptNumber %>&nbsp;</td>
                        <td class="iscs3">&nbsp;<%= parseFloat(row.Quantity).toFixed(3) %>&nbsp;</td>
                        <td class="iscs3">&nbsp;<%= parseFloat(row.AvgPrice).toFixed(2) %>&nbsp;</td>
                        <td class="iscs3">&nbsp;<%= parseFloat(row.Amount).toFixed(2) %>&nbsp;</td>
                        <td class="iscs3">&nbsp;<%= parseFloat(row.DiscountSum).toFixed(2) %>&nbsp;</td>
                        <td class="iscs3">&nbsp;<%= parseFloat(row.PaidAmount).toFixed(2) %>&nbsp;</td>
                        <td class="iscs3">&nbsp;<%= parseFloat(row.Surcharge5Pct).toFixed(2) %>&nbsp;</td>
                    </tr>
                <%
                            restRowNum++;
                        }
                %>
                    <tr class="rest-subtotal" style="background:#F0F0F0;" data-rest="<%= restaurant %>">
                        <td class="iscs4">&nbsp;<%= restaurant %> total&nbsp;</td>
                        <td class="iscs4">&nbsp;<%= restQty.toFixed(3) %>&nbsp;</td>
                        <td class="iscs4">&nbsp;<%= restQty > 0 ? (restAmt / restQty).toFixed(2) : '0.00' %>&nbsp;</td>
                        <td class="iscs4">&nbsp;<%= restAmt.toFixed(2) %>&nbsp;</td>
                        <td class="iscs4">&nbsp;<%= restDiscount.toFixed(2) %>&nbsp;</td>
                        <td class="iscs4">&nbsp;<%= restPaid.toFixed(2) %>&nbsp;</td>
                        <td class="iscs4">&nbsp;<%= restSurcharge.toFixed(2) %>&nbsp;</td>
                    </tr>
                <%
                    }
                %>
                    <tr id="grandTotalRow">
                        <td class="iscs9" colspan="2">&nbsp;Grand Total&nbsp;</td>
                        <td class="iscs9">&nbsp;<%= grandQty.toFixed(3) %>&nbsp;</td>
                        <td class="iscs9">&nbsp;<%= grandQty > 0 ? (grandAmt / grandQty).toFixed(2) : '0.00' %>&nbsp;</td>
                        <td class="iscs9">&nbsp;<%= grandAmt.toFixed(2) %>&nbsp;</td>
                        <td class="iscs9">&nbsp;<%= grandDiscount.toFixed(2) %>&nbsp;</td>
                        <td class="iscs9">&nbsp;<%= grandPaid.toFixed(2) %>&nbsp;</td>
                        <td class="iscs9">&nbsp;<%= grandSurcharge.toFixed(2) %>&nbsp;</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="mt-2 mb-4 no-print">
            <small class="text-muted">
                <i class="bi bi-info-circle"></i>
                Showing <span id="visibleCount"><%= data.length %></span> receipts | Generated: <%= new Date().toLocaleString() %>
            </small>
        </div>
        <% } else if (!error) { %>
        <div class="text-center text-muted py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <p class="mt-2">No data found. Please select a date range and click Run.</p>
        </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            var seen = {};
            var sel = document.getElementById('f_rec');
            document.querySelectorAll('#reportTable tbody tr[data-rec]').forEach(function(r) {
                var v = r.dataset.rec;
                if (!seen[v]) { seen[v] = true; var o = document.createElement('option'); o.value = v; o.textContent = v; sel.appendChild(o); }
            });
        })();

        function parseCompare(val, input) {
            input = input.trim();
            if (!input) return true;
            var num = parseFloat(val);
            if (input.indexOf('>=') === 0) return num >= parseFloat(input.slice(2));
            if (input.indexOf('<=') === 0) return num <= parseFloat(input.slice(2));
            if (input.indexOf('>') === 0) return num > parseFloat(input.slice(1));
            if (input.indexOf('<') === 0) return num < parseFloat(input.slice(1));
            if (input.indexOf('!=') === 0 || input.indexOf('<>') === 0) return num !== parseFloat(input.slice(2));
            if (input.indexOf('=') === 0) return num === parseFloat(input.slice(1));
            return val.toString().toLowerCase().indexOf(input.toLowerCase()) !== -1;
        }

        function filterTable() {
            var frest = document.getElementById('f_rest').value;
            var frec = document.getElementById('f_rec').value;
            var fqty = document.getElementById('f_qty').value;
            var favg = document.getElementById('f_avg').value;
            var famt = document.getElementById('f_amt').value;
            var fdisc = document.getElementById('f_disc').value;
            var fpaid = document.getElementById('f_paid').value;
            var fsc = document.getElementById('f_sc').value;
            var hasFilter = frest || frec || fqty || favg || famt || fdisc || fpaid || fsc;
            var rows = document.querySelectorAll('#reportTable tbody tr[data-rest]');
            var visibleRows = [];
            var visibleRests = {};

            rows.forEach(function(row) {
                var show = true;
                if (hasFilter) {
                    if (frest && row.dataset.rest.toLowerCase().indexOf(frest.toLowerCase()) === -1) show = false;
                    if (frec && row.dataset.rec !== frec) show = false;
                    if (fqty && !parseCompare(row.dataset.qty, fqty)) show = false;
                    if (favg && !parseCompare(row.dataset.avg, favg)) show = false;
                    if (famt && !parseCompare(row.dataset.amt, famt)) show = false;
                    if (fdisc && !parseCompare(row.dataset.disc, fdisc)) show = false;
                    if (fpaid && !parseCompare(row.dataset.paid, fpaid)) show = false;
                    if (fsc && !parseCompare(row.dataset.sc, fsc)) show = false;
                }
                row.style.display = show ? '' : 'none';
                if (show) { visibleRows.push(row); visibleRests[row.dataset.rest] = true; }
            });

            document.querySelectorAll('.rest-subtotal').forEach(function(st) {
                st.style.display = visibleRests[st.dataset.rest] ? '' : 'none';
            });

            document.getElementById('visibleCount').textContent = visibleRows.length;

            var grandRow = document.getElementById('grandTotalRow');
            if (grandRow) {
                var gQty = 0, gAmt = 0, gPaid = 0, gSurcharge = 0, gDiscount = 0;
                visibleRows.forEach(function(r) {
                    gQty += parseFloat(r.dataset.qty) || 0;
                    gAmt += parseFloat(r.dataset.amt) || 0;
                    gPaid += parseFloat(r.dataset.paid) || 0;
                    gSurcharge += parseFloat(r.dataset.sc) || 0;
                    gDiscount += parseFloat(r.dataset.disc) || 0;
                });
                var cells = grandRow.querySelectorAll('td');
                if (cells.length >= 7) {
                    cells[1].textContent = gQty.toFixed(3);
                    cells[2].textContent = gQty > 0 ? (gAmt / gQty).toFixed(2) : '0.00';
                    cells[3].textContent = gAmt.toFixed(2);
                    cells[4].textContent = gDiscount.toFixed(2);
                    cells[5].textContent = gPaid.toFixed(2);
                    cells[6].textContent = gSurcharge.toFixed(2);
                }
            }
        }

        function exportCSV() {
            var table = document.getElementById('reportTable');
            if (!table) return;
            var csv = [];
            table.querySelectorAll('tr').forEach(function(row) {
                if (row.style.display === 'none' || row.classList.contains('filter-row')) return;
                var rowData = [];
                row.querySelectorAll('td, th').forEach(function(col) {
                    rowData.push('"' + col.innerText.trim().replace(/"/g, '""') + '"');
                });
                csv.push(rowData.join(','));
            });
            var blob = new Blob([csv.join('\n')], { type: 'text/csv;charset=utf-8;' });
            var link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'receipt-report-' + new Date().toISOString().slice(0,10) + '.csv';
            link.click();
        }

        function clearFilters() {
            ['f_rest','f_rec','f_qty','f_avg','f_amt','f_disc','f_paid','f_sc'].forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.value = '';
            });
            filterTable();
        }

        document.getElementById('filterForm').addEventListener('submit', function(e) {
            var from = document.getElementById('DateFrom').value;
            var to = document.getElementById('DateTo').value;
            if (!from || !to) {
                e.preventDefault();
                alert('Please select both From and To dates.');
            }
        });
    </script>
</body>
</html>
